---
const title = "Processing Sign-In...";
const description = "Please wait while we sign you in.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      body {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
        font-family: system-ui, sans-serif;
        background: #f8fafc;
      }
      .spinner {
        border: 4px solid #f3f4f6;
        border-top: 4px solid #2563eb;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        animation: spin 1s linear infinite;
      }
      @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }
    </style>
  </head>
  <body>
    <div>
      <div class="spinner"></div>
      <p>Creating your session...</p>
    </div>

    <script is:inline>
      // Better Auth handles OAuth flow and session creation on the server
      // This page just handles the redirect after successful authentication
      // The Convex sync will be handled by the ConvexClientProvider
      window.location.href = "/overview";
    </script>
  </body>
</html>
