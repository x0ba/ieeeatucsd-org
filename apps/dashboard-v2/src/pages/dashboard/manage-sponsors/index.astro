---
import ClientDashboardLayout from "../../components/dashboard/shared/wrappers/ClientDashboardLayout.tsx";
import ManageSponsorsContent from "../../components/dashboard/pages/manage-sponsors/ManageSponsorsContent.tsx";
import NAVIGATION_PATHS from "../../components/dashboard/shared/types/navigation.ts";

const title = "Manage Sponsors - Dashboard";
const currentPath = NAVIGATION_PATHS.MANAGE_SPONSORS;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
</head>
<body>
    <ClientDashboardLayout currentPath={currentPath} client:load>
        <ManageSponsorsContent client:load />
    </ClientDashboardLayout>
</body>
</html>

