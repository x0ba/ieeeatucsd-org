---
import Layout from "../../layouts/Layout.astro";
import TestPublicProfilesContent from "../../components/dashboard/pages/test-public-profiles/TestPublicProfilesContent.tsx";
---

<Layout title="Test Public Profiles - IEEE UCSD Dashboard">
  <div id="test-root"></div>
</Layout>

<script>
  import { createElement } from "react";
  import { createRoot } from "react-dom/client";
  import TestPublicProfilesContent from "../../components/dashboard/pages/test-public-profiles/TestPublicProfilesContent.tsx";
  import ClientDashboardLayout from "../../components/dashboard/shared/wrappers/ClientDashboardLayout.tsx";

  const container = document.getElementById("test-root");
  if (container) {
    const root = createRoot(container);
    root.render(
      createElement(ClientDashboardLayout, {
        currentPath: "/test-public-profiles",
        children: createElement(TestPublicProfilesContent),
      }),
    );
  }
</script>
