---
import ClientDashboardLayout from "../../components/dashboard/shared/wrappers/ClientDashboardLayout.tsx";
import DashboardHead from "../../components/dashboard/shared/DashboardHead.astro";
import FundDepositsContent from "../../components/dashboard/pages/fund-deposits/FundDepositsContent.tsx";
import { NAVIGATION_PATHS } from "../../components/dashboard/shared/types/navigation";

const title = "Fund Deposits - Dashboard";
const currentPath = NAVIGATION_PATHS.FUND_DEPOSITS;
---

<!doctype html>
<html lang="en">
  <head>
    <DashboardHead title={title} />
  </head>
  <body>
    <ClientDashboardLayout currentPath={currentPath} client:load>
      <FundDepositsContent client:load />
    </ClientDashboardLayout>
  </body>
</html>
