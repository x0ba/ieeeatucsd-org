---
import ClientDashboardLayout from "../../../components/dashboard/shared/wrappers/ClientDashboardLayout.tsx";
import ResumeDatabaseContent from "../../../components/dashboard/pages/sponsors/ResumeDatabaseContent.tsx";
import { NAVIGATION_PATHS } from "../../../components/dashboard/shared/types/navigation";

const title = "Resume Database - Dashboard";
const currentPath = NAVIGATION_PATHS.RESUME_DATABASE;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <ClientDashboardLayout currentPath={currentPath} client:load>
      <ResumeDatabaseContent client:load />
    </ClientDashboardLayout>
  </body>
</html>
