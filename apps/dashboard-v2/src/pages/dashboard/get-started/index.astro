---
import GetStartedContent from '../../components/dashboard/pages/get-started/GetStartedContent.tsx';
import { getSession } from '../../lib/auth.ts';

// Check authentication and onboarding status
const session = await getSession(Astro.request);

if (!session) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: '/dashboard-v2/signin',
    },
  });
}

// Redirect if already onboarded
if (session.user.signedUp) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: '/dashboard-v2/overview',
    },
  });
}

const authUserId = session.user.id;
const email = session.user.email;
const name = session.user.name;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Get Started - IEEE at UC San Diego</title>
  </head>
  <body>
    <GetStartedContent
      client:load
      authUserId={authUserId}
      email={email}
      name={name}
    />
  </body>
</html>
