---
import ClientDashboardLayout from '../../components/dashboard/shared/wrappers/ClientDashboardLayout.tsx';
import DashboardHead from '../../components/dashboard/shared/DashboardHead.astro';
import EventsContent from '../../components/dashboard/pages/events/EventsContent.tsx';
import NAVIGATION_PATHS from '../../components/dashboard/shared/types/navigation.ts';

const title = "Events - Dashboard";
const currentPath = NAVIGATION_PATHS.EVENTS;
---

<!doctype html>
<html lang="en">
  <head>
    <DashboardHead title={title} />
  </head>
  <body>
    <ClientDashboardLayout currentPath={currentPath} client:load>
      <EventsContent client:load />
    </ClientDashboardLayout>
  </body>
</html>
