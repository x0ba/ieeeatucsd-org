---
import createDashboardPage from "../../components/dashboard/shared/wrappers/createDashboardPage.tsx";
import DashboardHead from "../../components/dashboard/shared/DashboardHead.astro";
import SlackAccessContent from "../../components/dashboard/pages/slack-access/SlackAccessContent.tsx";
import NAVIGATION_PATHS from "../../components/dashboard/shared/types/navigation.ts";

const title = "Slack Access - Dashboard";
const currentPath = NAVIGATION_PATHS.SLACK_ACCESS;
const SlackAccessPage = createDashboardPage(SlackAccessContent, currentPath);
---

<!doctype html>
<html lang="en">
  <head>
    <DashboardHead title={title} />
  </head>
  <body>
    <SlackAccessPage client:only="react" />
  </body>
</html>
