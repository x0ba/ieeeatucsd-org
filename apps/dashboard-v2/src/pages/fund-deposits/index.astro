---
import createDashboardPage from "../../components/dashboard/shared/wrappers/createDashboardPage.tsx";
import DashboardHead from "../../components/dashboard/shared/DashboardHead.astro";
import FundDepositsContent from "../../components/dashboard/pages/fund-deposits/FundDepositsContent.tsx";
import NAVIGATION_PATHS from "../../components/dashboard/shared/types/navigation.ts";

const title = "Fund Deposits - Dashboard";
const currentPath = NAVIGATION_PATHS.FUND_DEPOSITS;
const FundDepositsPage = createDashboardPage(FundDepositsContent, currentPath);
---

<!doctype html>
<html lang="en">
  <head>
    <DashboardHead title={title} />
  </head>
  <body>
    <FundDepositsPage client:only="react" />
  </body>
</html>
