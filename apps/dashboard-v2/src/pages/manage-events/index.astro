---
import createDashboardPage from '../../components/dashboard/shared/wrappers/createDashboardPage.tsx';
import DashboardHead from '../../components/dashboard/shared/DashboardHead.astro';
import ManageEventsContent from '../../components/dashboard/pages/manage-events/ManageEventsContent.tsx';
import NAVIGATION_PATHS from "../../components/dashboard/shared/types/navigation.ts";

const title = "Manage Events - Dashboard";
const currentPath = NAVIGATION_PATHS.MANAGE_EVENTS;
const ManageEventsPage = createDashboardPage(ManageEventsContent, currentPath);
---

