{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*", "convex/**/*"],
  "exclude": ["dist", "node_modules"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strict": false,
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "~/convex": ["./convex"],
      "~/convex/*": ["./convex/*"],
      "#convex/*": ["./convex/*"],
      "@convex/*": ["./convex/*"]
    },
    "types": ["astro/client"]
  }
}
