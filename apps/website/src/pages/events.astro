---
import Layout from "../layouts/Layout.astro";
import EventTitle from "../components/events/EventTitle.astro";
import { Image } from "astro:assets";
import eventborder from "../images/eventborder.webp";
import UpcomingEvents from "../components/events/UpcomingEvents.astro";
import Calendar from "../components/events/Calendar.jsx";
import AllEventsList from "../components/events/AllEventsList.jsx";
import { fetchPublishedEventsFromConvex } from "../lib/convexEvents";

const events = await fetchPublishedEventsFromConvex();
const publicCalendarId = import.meta.env.PUBLIC_GOOGLE_CALENDAR_ID || "";

const seoProps = {
  title: "Events - IEEE at UC San Diego",
  description:
    "Discover upcoming workshops, technical talks, networking events, and competitions hosted by IEEE at UC San Diego. Join us for hands-on learning and professional development opportunities.",
  keywords: [
    "IEEE UCSD events",
    "engineering workshops",
    "technical talks",
    "UCSD tech events",
    "student competitions",
    "networking events",
    "engineering calendar",
  ],
  image: "/calendar.webp",
};
---

<Layout {...seoProps}>
  <Image
    src={eventborder}
    alt="JOIN US"
    class="absolute left-[1vw] md:w-[4vw] w-[5vw] md:top-[60vh] top-[70vw] -z-10"
  />
  <Image
    src={eventborder}
    alt="JOIN US"
    class="absolute right-[1vw] md:w-[4vw] w-[5vw] md:top-[60vh] top-[70vw] -z-10"
  />
  <EventTitle />
  <UpcomingEvents events={events} />
  <div class="flex justify-center pb-[10%]">
    <Calendar client:load events={events} publicCalendarId={publicCalendarId} />
  </div>

  <AllEventsList client:load events={events} publicCalendarId={publicCalendarId} />
</Layout>
