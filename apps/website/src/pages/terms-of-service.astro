---
import Layout from "../layouts/Layout.astro";
import Title from "../components/core/Title.astro";
import Subtitle from "../components/core/Subtitle.astro";
import { LEGAL_VERSIONS, formatEffectiveDate } from "../config/legalVersions";

const pageData = {
  title: "Terms of Service",
  description:
    "Terms and conditions for using IEEE UC San Diego Student Branch's services and platform.",
};

const lastUpdated = formatEffectiveDate(LEGAL_VERSIONS.TOS_EFFECTIVE_DATE);
---

<Layout title={pageData.title} description={pageData.description}>
  <main class="min-h-screen bg-ieee-black">


    <!-- Table of Contents (Mobile Only) -->
    <section class="py-8 bg-base-300/30 lg:hidden">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8"
        >
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <svg
              class="w-6 h-6 text-ieee-yellow"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
            </svg>
            Table of Contents
          </h2>
          <nav class="grid md:grid-cols-2 gap-3">
            <a
              href="#acceptance"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">1.</span>
              <span>Acceptance of Terms</span>
            </a>
            <a
              href="#user-accounts"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">2.</span>
              <span>User Accounts</span>
            </a>
            <a
              href="#permitted-use"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">3.</span>
              <span>Permitted Use</span>
            </a>
            <a
              href="#prohibited-conduct"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">4.</span>
              <span>Prohibited Conduct</span>
            </a>
            <a
              href="#intellectual-property"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">5.</span>
              <span>Intellectual Property</span>
            </a>
            <a
              href="#user-content"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">6.</span>
              <span>User Content</span>
            </a>
            <a
              href="#disclaimers"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">7.</span>
              <span>Disclaimers</span>
            </a>
            <a
              href="#limitation-liability"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">8.</span>
              <span>Limitation of Liability</span>
            </a>
            <a
              href="#changes-terms"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">9.</span>
              <span>Changes to Terms</span>
            </a>
            <a
              href="#contact-tos"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">10.</span>
              <span>Contact Information</span>
            </a>
          </nav>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-12 lg:gap-12">
          <!-- Desktop Sidebar -->
          <div class="hidden lg:block lg:col-span-3">
            <nav class="sticky top-24 space-y-1">
              <h2 class="text-xs font-bold text-white/40 uppercase tracking-widest mb-6 px-3">
                On this page
              </h2>
              <a href="#acceptance" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                1. Acceptance
              </a>
              <a href="#user-accounts" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                2. User Accounts
              </a>
              <a href="#permitted-use" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                3. Permitted Use
              </a>
              <a href="#prohibited-conduct" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                4. Prohibited Conduct
              </a>
              <a href="#intellectual-property" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                5. Intellectual Property
              </a>
              <a href="#user-content" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                6. User Content
              </a>
              <a href="#disclaimers" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                7. Disclaimers
              </a>
              <a href="#limitation-liability" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                8. Limitation of Liability
              </a>
              <a href="#changes-terms" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                9. Changes to Terms
              </a>
              <a href="#contact-tos" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                10. Contact
              </a>
            </nav>
          </div>

          <!-- Main Content -->
          <div class="lg:col-span-9 space-y-12">
            <!-- Page Header -->
            <div class="space-y-6 mb-12">
              <div class="inline-flex items-center gap-2 px-3 py-1 bg-ieee-yellow/10 border border-ieee-yellow/20 rounded-full">
                <span class="text-xs font-medium text-ieee-yellow">Legal Agreement</span>
              </div>
              <h1 class="text-4xl md:text-5xl font-bold text-white">Terms of Service</h1>
              <p class="text-white/60">Last updated: {lastUpdated}</p>
              <p class="text-lg text-white/80 leading-relaxed max-w-3xl">
                Welcome to IEEE UC San Diego Student Branch. By accessing or using our services, you agree to be bound by these Terms of Service. Please read them carefully before using our platform.
              </p>
            </div>
        <!-- 1. Acceptance of Terms -->
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8 hover:border-ieee-yellow/30 transition-colors"
          id="acceptance"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="p-3 bg-ieee-yellow/10 rounded-xl">
              <svg
                class="w-6 h-6 text-ieee-yellow"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-white">
                1. Acceptance of Terms
              </h2>
              <p class="text-white/60 text-sm mt-1">
                Your agreement to these terms
              </p>
            </div>
          </div>

          <div class="space-y-4 text-white/80">
            <p>
              By accessing or using the IEEE UC San Diego Student Branch website, dashboard, and
              related services (collectively, the "Services"), you agree to be
              bound by these Terms of Service ("Terms"). If you do not agree to
              these Terms, please do not use our Services.
            </p>
            <p>
              These Terms constitute a legally binding agreement between you and
              IEEE UC San Diego Student Branch ("IEEE UCSD"), a registered student organization at the University
              of California, San Diego and an official IEEE Student Branch.
            </p>
            <div class="bg-base-300/50 rounded-lg p-4 border border-white/5">
              <p class="text-sm">
                <strong class="text-white">Important:</strong> You must be at least
                18 years old or have parental/guardian consent to use our Services.
                By using our Services, you represent that you meet this requirement.
              </p>
            </div>
          </div>
        </div>

        <!-- 2. User Accounts -->
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8 hover:border-ieee-yellow/30 transition-colors"
          id="user-accounts"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="p-3 bg-ieee-yellow/10 rounded-xl">
              <svg
                class="w-6 h-6 text-ieee-yellow"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                ></path>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-white">2. User Accounts</h2>
              <p class="text-white/60 text-sm mt-1">
                Account registration and security
              </p>
            </div>
          </div>

          <div class="space-y-4 text-white/80">
            <p>
              To access certain features of our Services, you may need to create
              an account. When creating an account, you agree to:
            </p>
            <ul class="space-y-2 ml-6">
              <li class="flex items-start gap-2">
                <span class="text-ieee-yellow mt-1">•</span>
                <span
                  >Provide accurate, current, and complete information during
                  registration</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-ieee-yellow mt-1">•</span>
                <span
                  >Maintain and update your information to keep it accurate</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-ieee-yellow mt-1">•</span>
                <span
                  >Maintain the security of your account credentials and not
                  share them with others</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-ieee-yellow mt-1">•</span>
                <span
                  >Notify us immediately of any unauthorized access to your
                  account</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-ieee-yellow mt-1">•</span>
                <span
                  >Accept responsibility for all activities that occur under
                  your account</span
                >
              </li>
            </ul>
            <p>
              We reserve the right to suspend or terminate accounts that violate
              these Terms or for any other reason at our discretion.
            </p>
          </div>
        </div>

        <!-- 3. Permitted Use -->
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8 hover:border-ieee-yellow/30 transition-colors"
          id="permitted-use"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="p-3 bg-ieee-yellow/10 rounded-xl">
              <svg
                class="w-6 h-6 text-ieee-yellow"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-white">3. Permitted Use</h2>
              <p class="text-white/60 text-sm mt-1">
                How you may use our Services
              </p>
            </div>
          </div>

          <div class="space-y-4 text-white/80">
            <p>You may use our Services for the following purposes:</p>
            <div class="grid gap-4">
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Event Participation:</strong>
                  <span>
                    Registering for, checking into, and participating in IEEE
                    UC San Diego Student Branch events</span
                  >
                </div>
              </div>
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Financial Services:</strong>
                  <span>
                    Submitting reimbursement requests and managing fund deposits</span
                  >
                </div>
              </div>
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Member Features:</strong>
                  <span>
                    Accessing your profile, viewing leaderboards, and connecting
                    with the community</span
                  >
                </div>
              </div>
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Career Development:</strong>
                  <span>
                    Uploading resumes and connecting with sponsors (with your
                    consent)</span
                  >
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 4. Prohibited Conduct -->
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8 hover:border-ieee-yellow/30 transition-colors"
          id="prohibited-conduct"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="p-3 bg-red-500/10 rounded-xl">
              <svg
                class="w-6 h-6 text-red-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"
                ></path>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-white">
                4. Prohibited Conduct
