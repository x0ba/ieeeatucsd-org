          </div>

          <div class="space-y-4 text-white/80">
            <p>When using our Services, you agree NOT to:</p>
            <ul class="space-y-2 ml-6">
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-1">✕</span>
                <span
                  >Violate any applicable laws, regulations, or university
                  policies</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-1">✕</span>
                <span
                  >Impersonate any person or entity or misrepresent your
                  affiliation</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-1">✕</span>
                <span
                  >Submit false or fraudulent information, including fake
                  receipts or event check-ins</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-1">✕</span>
                <span
                  >Attempt to gain unauthorized access to other users' accounts
                  or our systems</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-1">✕</span>
                <span
                  >Interfere with or disrupt the Services or servers/networks
                  connected to them</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-1">✕</span>
                <span
                  >Upload viruses, malware, or other malicious code</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-1">✕</span>
                <span
                  >Harass, abuse, or harm other users or organization members</span
                >
              </li>
              <li class="flex items-start gap-2">
                <span class="text-red-400 mt-1">✕</span>
                <span
                  >Use the Services for any commercial purpose without our
                  written consent</span
                >
              </li>
            </ul>
          </div>
        </div>

        <!-- 5. Intellectual Property -->
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8 hover:border-ieee-yellow/30 transition-colors"
          id="intellectual-property"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="p-3 bg-ieee-yellow/10 rounded-xl">
              <svg
                class="w-6 h-6 text-ieee-yellow"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                ></path>
              </svg>
            </div>
