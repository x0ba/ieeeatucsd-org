---
import Layout from "../layouts/Layout.astro";
import Title from "../components/core/Title.astro";
import Subtitle from "../components/core/Subtitle.astro";
import { LEGAL_VERSIONS, formatEffectiveDate } from "../config/legalVersions";

const pageData = {
  title: "Privacy Policy",
  description:
    "Learn how IEEE UC San Diego Student Branch collects, uses, and protects your personal information.",
};

const lastUpdated = formatEffectiveDate(LEGAL_VERSIONS.PRIVACY_POLICY_EFFECTIVE_DATE);
---

<Layout title={pageData.title} description={pageData.description}>
  <main class="min-h-screen bg-ieee-black">


    <!-- Table of Contents (Mobile Only) -->
    <section class="py-8 bg-base-300/30 lg:hidden">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8"
        >
          <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <svg
              class="w-6 h-6 text-ieee-yellow"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
            </svg>
            Table of Contents
          </h2>
          <nav class="grid md:grid-cols-2 gap-3">
            <a
              href="#information-collect"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">1.</span>
              <span>Information We Collect</span>
            </a>
            <a
              href="#how-we-use"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">2.</span>
              <span>How We Use Your Information</span>
            </a>
            <a
              href="#information-sharing"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">3.</span>
              <span>Information Sharing and Disclosure</span>
            </a>
            <a
              href="#data-storage"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">4.</span>
              <span>Data Storage and Security</span>
            </a>
            <a
              href="#data-retention"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">5.</span>
              <span>Data Retention</span>
            </a>
            <a
              href="#your-rights"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">6.</span>
              <span>Your Rights and Choices</span>
            </a>
            <a
              href="#cookies-tracking"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">7.</span>
              <span>Cookies and Tracking</span>
            </a>
            <a
              href="#international-transfers"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">8.</span>
              <span>International Data Transfers</span>
            </a>
            <a
              href="#policy-changes"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">9.</span>
              <span>Changes to This Policy</span>
            </a>
            <a
              href="#contact-info"
              class="flex items-center gap-2 text-white/80 hover:text-ieee-yellow transition-colors p-3 rounded-lg hover:bg-base-300/50"
            >
              <span class="text-ieee-yellow font-semibold">10.</span>
              <span>Contact Information</span>
            </a>
          </nav>
        </div>
      </div>
    </section>

    <!-- Content Section -->
    <section class="py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="lg:grid lg:grid-cols-12 lg:gap-12">
          <!-- Desktop Sidebar -->
          <div class="hidden lg:block lg:col-span-3">
            <nav class="sticky top-24 space-y-1">
              <h2 class="text-xs font-bold text-white/40 uppercase tracking-widest mb-6 px-3">
                On this page
              </h2>
              <a href="#information-collect" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                1. Information We Collect
              </a>
              <a href="#how-we-use" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                2. How We Use It
              </a>
              <a href="#information-sharing" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                3. Information Sharing
              </a>
              <a href="#data-storage" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                4. Storage & Security
              </a>
              <a href="#data-retention" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                5. Data Retention
              </a>
              <a href="#your-rights" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                6. Your Rights
              </a>
              <a href="#cookies-tracking" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                7. Cookies
              </a>
              <a href="#international-transfers" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                8. International Transfers
              </a>
              <a href="#policy-changes" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                9. Changes
              </a>
              <a href="#contact-info" class="block text-sm text-white/70 hover:text-white hover:bg-white/5 px-3 py-2 rounded-lg transition-colors border-l-2 border-transparent hover:border-ieee-yellow/50">
                10. Contact
              </a>
            </nav>
          </div>

          <!-- Main Content -->
          <div class="lg:col-span-9 space-y-12">
            <!-- Page Header -->
            <div class="space-y-6 mb-12">
              <div class="inline-flex items-center gap-2 px-3 py-1 bg-ieee-yellow/10 border border-ieee-yellow/20 rounded-full">
                <span class="text-xs font-medium text-ieee-yellow">Your Privacy Matters</span>
              </div>
              <h1 class="text-4xl md:text-5xl font-bold text-white">Privacy Policy</h1>
              <p class="text-white/60">Last updated: {lastUpdated}</p>
              <p class="text-lg text-white/80 leading-relaxed max-w-3xl">
                At IEEE at UCSD, we are committed to protecting your privacy and ensuring the security of your personal information. This privacy policy explains how we collect, use, and safeguard your data.
              </p>
            </div>
        <!-- 1. Information We Collect -->
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8 hover:border-ieee-yellow/30 transition-colors"
          id="information-collect"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="p-3 bg-ieee-yellow/10 rounded-xl">
              <svg
                class="w-6 h-6 text-ieee-yellow"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                ></path>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-white">
                1. Information We Collect
              </h2>
              <p class="text-white/60 text-sm mt-1">
                What data we gather and why
              </p>
            </div>
          </div>

          <div class="space-y-6">
            <div class="bg-base-300/50 rounded-xl p-6 border border-white/5">
              <div class="flex items-center gap-3 mb-4">
                <svg
                  class="w-5 h-5 text-ieee-yellow"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                  ></path>
                </svg>
                <h3 class="text-lg font-semibold text-white">
                  Personal Information
                </h3>
              </div>
              <ul class="space-y-2 text-white/80 ml-8">
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Name, email address, and profile picture (from Google OAuth
                    or email signup)</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Academic information (major, graduation year, student PID,
                    IEEE member ID)</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Contact preferences, display settings, and accessibility
                    preferences</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Payment information (Zelle details for reimbursements only)</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >IEEE email address and credentials (when you request an
                    @ieeeucsd.org account)</span
                  >
                </li>
              </ul>
            </div>

            <div class="bg-base-300/50 rounded-xl p-6 border border-white/5">
              <div class="flex items-center gap-3 mb-4">
                <svg
                  class="w-5 h-5 text-ieee-yellow"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                  ></path>
                </svg>
                <h3 class="text-lg font-semibold text-white">Activity Data</h3>
              </div>
              <ul class="space-y-2 text-white/80 ml-8">
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Event attendance records, check-in codes, food preferences,
                    and participation points</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Account creation date, last login time, and authentication
                    method used</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Reimbursement requests, receipts, and financial transaction
                    records</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Resume files (optional, stored only if you choose to upload
                    for sponsor sharing)</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span>Event files and attachments uploaded by officers</span>
                </li>
              </ul>
            </div>

            <div class="bg-base-300/50 rounded-xl p-6 border border-white/5">
              <div class="flex items-center gap-3 mb-4">
                <svg
                  class="w-5 h-5 text-ieee-yellow"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <h3 class="text-lg font-semibold text-white">
                  Technical Information
                </h3>
              </div>
              <ul class="space-y-2 text-white/80 ml-8">
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span>IP addresses (for security and session management)</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span>Browser type, version, and device information</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Authentication method (Google OAuth or email/password)</span
                  >
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-ieee-yellow mt-1">•</span>
                  <span
                    >Session cookies for authentication and preference storage
                    (no analytics tracking)</span
                  >
                </li>
              </ul>
            </div>
          </div>
        </div>

        <!-- 2. How We Use Your Information -->
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8 hover:border-ieee-yellow/30 transition-colors"
          id="how-we-use"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="p-3 bg-ieee-yellow/10 rounded-xl">
              <svg
                class="w-6 h-6 text-ieee-yellow"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-white">
                2. How We Use Your Information
              </h2>
              <p class="text-white/60 text-sm mt-1">
                The purposes for data processing
              </p>
            </div>
          </div>

          <div class="space-y-4">
            <p class="text-white/80">
              We use the information we collect for the following purposes:
            </p>
            <div class="grid gap-4">
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Membership Management:</strong>
                  <span class="text-white/80">
                    Process memberships, track participation, manage user roles
                    and permissions, and provide organizational services</span
                  >
                </div>
              </div>
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Event Management:</strong>
                  <span class="text-white/80">
                    Register attendees, track check-ins, manage food
                    preferences, award participation points, and sync with
                    calendar</span
                  >
                </div>
              </div>
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Financial Operations:</strong>
                  <span class="text-white/80">
                    Process reimbursement requests, parse receipts using AI,
                    maintain financial records, and manage fund deposits</span
                  >
                </div>
              </div>
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Career Services:</strong>
                  <span class="text-white/80">
                    Share resumes with sponsors (only with your explicit
                    consent) and provide networking opportunities</span
                  >
                </div>
              </div>
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Communication:</strong>
                  <span class="text-white/80">
                    Send organizational updates, event notifications,
                    reimbursement status updates, and manage IEEE email services</span
                  >
                </div>
              </div>
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Security:</strong>
                  <span class="text-white/80">
                    Prevent unauthorized access, detect fraud, maintain system
                    integrity, and protect member data</span
                  >
                </div>
              </div>
              <div
                class="bg-base-300/50 rounded-lg p-4 border border-white/5 flex items-start gap-3"
              >
                <svg
                  class="w-5 h-5 text-ieee-yellow mt-0.5 flex-shrink-0"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                  ></path>
                </svg>
                <div>
                  <strong class="text-white">Legal Compliance:</strong>
                  <span class="text-white/80">
                    Meet organizational requirements, comply with university
                    policies, and fulfill regulatory obligations</span
                  >
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- 3. Information Sharing and Disclosure -->
        <div
          class="bg-base-200/80 backdrop-blur-sm rounded-2xl shadow-lg border border-white/10 p-8 hover:border-ieee-yellow/30 transition-colors"
          id="information-sharing"
        >
          <div class="flex items-start gap-4 mb-6">
            <div class="p-3 bg-ieee-yellow/10 rounded-xl">
              <svg
                class="w-6 h-6 text-ieee-yellow"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"
                ></path>
