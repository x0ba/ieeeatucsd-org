---
import Navbar from "../components/core/Navbar.astro";
import Footer from "../components/core/Footer.astro";
import InView from "../components/core/InView.astro";
import SEO from "../components/core/SEO.astro";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article" | "profile";
  noindex?: boolean;
  nofollow?: boolean;
  keywords?: string[];
  structuredData?: object;
}

const seoProps = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark" class="w-full h-full m-0 bg-ieee-black">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <SEO {...seoProps} />

    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link
      rel="icon"
      type="image/png"
      sizes="192x192"
      href="/android-chrome-192x192.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="512x512"
      href="/android-chrome-512x512.png"
    />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Iconify -->
    <script
      src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"
    ></script>

    <!-- Theme Script -->
    <script is:inline>
      // Set default theme to dark if not already set
      if (!localStorage.getItem("theme")) {
        localStorage.setItem("theme", "dark");
        document.documentElement.setAttribute("data-theme", "dark");
      } else {
        // Apply saved theme
        const savedTheme = localStorage.getItem("theme");
        document.documentElement.setAttribute("data-theme", savedTheme);
      }
    </script>
  </head>
  <InView />
  <body class="w-full h-full m-0 bg-ieee-black">
    <div class="text-white min-h-screen">
      <header class="sticky top-0 w-full z-[999]">
        <Navbar />
      </header>
      <main class="w-[95%] mx-auto">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
