---
import { Image } from "astro:assets";
import background from "../../images/robocup_bg.jpeg";
import roboLogo from "../../images/triton_bots_logo.png";
import Link from "next/link";
---

<div
    class="flex items-center md:h-[35vw] h-[45vw] relative w-full pl-[10%] md:mt-[3%] mt-[10%] mb-[10%]"
>
    <Image
        src={background}
        alt="Robocup Background"
        class="absolute w-screen right-0 top-0 opacity-90 h-[40vw]"
    />
    <div
        class="absolute w-screen right-0 top-0 h-[40vw] bg-gradient-to-r from-ieee-black via-ieee-black/80"
    />
    <div
    class="z-10 flex items-center md:text-[4vw] text-[4.5vw] ml-[7%] md:pt-[5%] pt-[10%] text-white font-semibold"
    >
        
        <Image src={roboLogo} alt="Triton RoboCup Team Logo" class=" mr-[1vw] w-[10vw]" />
        <div class="flex flex-col">
            <p>TritonBots RoboCup SSL Team</p>
            <div class="-mt-[2vw]">
            <Link className="text-[1.2vw]" href = "https://docs.google.com/forms/d/e/1FAIpQLSdigg2WPFvAGwaeY_i7uTEPkDplRUkPFb3w5SJLEQeZYNviXw/viewform?usp=sharing&ouid=108575348199269065111" target="_blank" className="md:text-[1.2vw] text-[2vw] font-light border-white/70 border-[0.1vw] py-[1.5%] px-[10%] rounded-[0.5vw] hover:text-ieee-yellow hover:border-ieee-yellow duration-300">
                    Interested? Apply Here
            </Link>
            </div>
        </div>
    </div>
</div>
