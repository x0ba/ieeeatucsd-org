---
// Dynamic route for shortened URLs (e.g., /meeting, /zoom-link)
import { getFirestore } from "firebase-admin/firestore";
import { app } from "../firebase/server";

export const prerender = false; // This route needs to be server-side rendered

const db = getFirestore(app);

const { slug } = Astro.params;

// Ensure slug exists
if (!slug) {
  return Astro.redirect("/404", 404);
}

// Skip if this is a known route (prevent conflicts)
const knownRoutes = [
  "board",
  "dashboard",
  "events",
  "find",
  "join",
  "projects",
  "reimbursement",
  "status-images",
  "api",
  "404",
];

if (knownRoutes.includes(slug)) {
  return Astro.redirect("/404", 404);
}

try {
  // Query Firebase directly for the link with the matching shortUrl
  const linksRef = db.collection("links");
  const querySnapshot = await linksRef.where("shortUrl", "==", slug).get();

  if (querySnapshot.empty) {
    console.log(`Link not found for slug: ${slug}`);
    return Astro.redirect("/404", 404);
  }

  const linkDoc = querySnapshot.docs[0];
  const linkData = linkDoc.data();

  // Check publish/expire dates
  const now = new Date();

  // Check if link is published (publishDate is in the future)
  if (linkData.publishDate) {
    const publishDate = linkData.publishDate.toDate();
    if (publishDate > now) {
      console.log(`Link not yet published for slug: ${slug}`);
      return Astro.redirect("/404", 404);
    }
  }

  // Check if link is expired (expireDate is in the past)
  if (linkData.expireDate) {
    const expireDate = linkData.expireDate.toDate();
    if (expireDate < now) {
      console.log(`Link has expired for slug: ${slug}`);
      return Astro.redirect("/404", 404);
    }
  }

  // Redirect to the actual URL
  console.log(`Redirecting slug ${slug} to ${linkData.url}`);
  return Astro.redirect(linkData.url, 302);
} catch (error) {
  console.error("Error handling shortened URL redirect:", error);
  return Astro.redirect("/404", 500);
}
---
