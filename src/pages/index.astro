---
import Layout from "../layouts/Layout.astro";
import Landing from "../components/main_page/Landing.astro";
import Divider from "../components/main_page/Divider.astro";
import Social from "../components/core/Social.astro";
import About from "../components/main_page/About.astro";
import Activities from "../components/main_page/Activities.astro";

const seoProps = {
  title: "IEEE at UC San Diego - Join One of the Largest IEEE Student Branches",
  description:
    "Join one of the largest IEEE student branches in the US! IEEE @ UCSD empowers students through technical projects, workshops, networking, and professional development opportunities in engineering and technology.",
  keywords: [
    "IEEE UCSD",
    "UC San Diego engineering",
    "student organization",
    "robotics",
    "quarterly projects",
    "technical workshops",
    "engineering networking",
    "UCSD student branch",
  ],
  image: "/logos/blue_logo_only.png",
  imageAlt: "IEEE at UC San Diego Logo",
};
---

<Layout {...seoProps}>
  <Landing />
  <Divider />
  <About />
  <Activities />
  <Social />
</Layout>
