---
/**
 * Dashboard Offline Fallback Page
 * Displayed when dashboard users are offline and try to access a page that's not cached
 */
const title = "You're Offline - IEEE UCSD Dashboard";
---

<!doctype html>
<html lang="en" class="w-full h-full m-0">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/dashboard/manifest.json" />
    
    <!-- Theme color -->
    <meta name="theme-color" content="#00629B" />
    
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        background: #f9fafb;
        color: #111827;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px;
      }
      
      .container {
        text-align: center;
        max-width: 600px;
        padding: 40px;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
      }
      
      .icon {
        width: 120px;
        height: 120px;
        margin: 0 auto 30px;
        background: linear-gradient(135deg, #00629B 0%, #0088cc 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        animation: pulse 2s ease-in-out infinite;
      }
      
      .icon svg {
        width: 60px;
        height: 60px;
        fill: white;
      }
      
      @keyframes pulse {
        0%, 100% {
          transform: scale(1);
          opacity: 1;
        }
        50% {
          transform: scale(1.05);
          opacity: 0.8;
        }
      }
      
      h1 {
        font-size: 2rem;
        margin-bottom: 15px;
        color: #111827;
        font-weight: 700;
      }
      
      p {
        font-size: 1rem;
        line-height: 1.6;
        color: #6b7280;
        margin-bottom: 30px;
      }
      
      .button {
        display: inline-block;
        padding: 12px 32px;
        background: linear-gradient(135deg, #00629B 0%, #0088cc 100%);
        color: white;
        text-decoration: none;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        margin: 8px;
      }
      
      .button:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(0, 98, 155, 0.3);
      }
      
      .button.secondary {
        background: #f3f4f6;
        color: #374151;
      }
      
      .button.secondary:hover {
        background: #e5e7eb;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      }
      
      .status {
        margin-top: 30px;
        padding: 15px;
        background: #fef3c7;
        border-radius: 10px;
        font-size: 0.9rem;
        color: #92400e;
        border: 1px solid #fde68a;
      }
      
      .status.online {
        background: #d1fae5;
        color: #065f46;
        border: 1px solid #a7f3d0;
      }
      
      .logo {
        width: 60px;
        height: auto;
        margin-bottom: 20px;
        opacity: 0.9;
      }
      
      .features {
        margin-top: 40px;
        padding-top: 30px;
        border-top: 1px solid #e5e7eb;
      }
      
      .features h2 {
        font-size: 1.1rem;
        color: #374151;
        margin-bottom: 20px;
        font-weight: 600;
      }
      
      .feature-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 20px;
        text-align: left;
      }
      
      .feature-item {
        padding: 15px;
        background: #f9fafb;
        border-radius: 10px;
        border: 1px solid #e5e7eb;
      }
      
      .feature-item h3 {
        font-size: 0.9rem;
        color: #00629B;
        margin-bottom: 5px;
        font-weight: 600;
      }
      
      .feature-item p {
        font-size: 0.8rem;
        color: #6b7280;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <img src="/android-chrome-192x192.png" alt="IEEE UCSD Logo" class="logo" />
      
      <div class="icon">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
        </svg>
      </div>
      
      <h1>You're Offline</h1>
      
      <p>
        It looks like you've lost your internet connection. Some dashboard features may still be available from your cache.
      </p>
      
      <div id="status" class="status">
        Checking connection status...
      </div>
      
      <div style="margin-top: 30px;">
        <button onclick="window.location.reload()" class="button">
          Try Again
        </button>
        <a href="/dashboard/" class="button secondary">
          Go to Dashboard Home
        </a>
      </div>
      
      <div class="features">
        <h2>What you can do offline:</h2>
        <div class="feature-grid">
          <div class="feature-item">
            <h3>📄 View Cached Pages</h3>
            <p>Access recently viewed dashboard pages</p>
          </div>
          <div class="feature-item">
            <h3>📊 Review Data</h3>
            <p>View cached member and event information</p>
          </div>
          <div class="feature-item">
            <h3>🔄 Auto-Sync</h3>
            <p>Changes will sync when you're back online</p>
          </div>
        </div>
      </div>
    </div>
    
    <script is:inline>
      // Check online status
      function updateOnlineStatus() {
        const statusEl = document.getElementById('status');
        if (navigator.onLine) {
          statusEl.textContent = '✓ Connection restored! Click "Try Again" to continue.';
          statusEl.className = 'status online';
        } else {
          statusEl.textContent = '✗ No internet connection detected.';
          statusEl.className = 'status';
        }
      }
      
      // Update status on load
      updateOnlineStatus();
      
      // Listen for online/offline events
      window.addEventListener('online', updateOnlineStatus);
      window.addEventListener('offline', updateOnlineStatus);
      
      // Auto-reload when connection is restored
      window.addEventListener('online', () => {
        setTimeout(() => {
          window.location.reload();
        }, 2000);
      });
    </script>
  </body>
</html>

