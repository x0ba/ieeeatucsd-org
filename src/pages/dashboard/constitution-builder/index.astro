---
import DashboardLayout from "../../../components/dashboard/shared/DashboardLayout.tsx";
import DashboardHead from "../../../components/dashboard/shared/DashboardHead.astro";
import ConstitutionBuilderContent from "../../../components/dashboard/pages/constitution-builder/ConstitutionBuilderContent.tsx";
import { NAVIGATION_PATHS } from "../../../components/dashboard/shared/types/navigation";

const title = "Constitution Builder - Dashboard";
const currentPath = NAVIGATION_PATHS.CONSTITUTION_BUILDER;
---

<!doctype html>
<html lang="en">
  <head>
    <DashboardHead title={title} />
  </head>
  <body>
    <DashboardLayout currentPath={currentPath} client:load>
      <ConstitutionBuilderContent client:load />
    </DashboardLayout>
  </body>
</html>
