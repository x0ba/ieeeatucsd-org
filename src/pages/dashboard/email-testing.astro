---
import DashboardHead from "../../components/dashboard/shared/DashboardHead.astro";
import DashboardLayout from "../../components/dashboard/shared/DashboardLayout.tsx";

const title = "Email Testing - Dashboard";
const currentPath = "/dashboard/email-testing";
---

<!doctype html>
<html lang="en">
  <head>
    <DashboardHead title={title} />
  </head>
  <body>
    <DashboardLayout currentPath={currentPath} client:load>
      <div class="email-testing-container">
        <h1>Email Testing Dashboard</h1>
        <p class="subtitle">
          Test email notifications using production routes with realistic data
        </p>

        <div class="test-form">
          <div class="form-group">
            <label for="test-email">Test Email Address</label>
            <input
              type="email"
              id="test-email"
              placeholder="your.email@example.com"
              required
            />
          </div>

          <div class="form-group">
            <label for="email-type">Email Type</label>
            <select id="email-type" required>
              <option value="">Select an email type...</option>
              <optgroup label="Reimbursements">
                <option value="reimbursement_submission"
                  >Reimbursement Submission</option
                >
                <option value="reimbursement_status_change_approved"
                  >Reimbursement Approved</option
                >
                <option value="reimbursement_status_change_rejected"
                  >Reimbursement Rejected</option
                >
                <option value="reimbursement_status_change_paid"
                  >Reimbursement Paid</option
                >
                <option value="audit_request">Audit Request</option>
              </optgroup>
              <optgroup label="Events">
                <option value="event_submission"
                  >Event Request Submission</option
                >
                <option value="event_status_change">Event Status Change</option>
                <option value="event_edit">Event Edit</option>
                <option value="event_delete">Event Delete</option>
                <option value="graphics_upload">Graphics Upload</option>
              </optgroup>
              <optgroup label="Fund Deposits">
                <option value="fund_deposit_submission"
                  >Fund Deposit Submission</option
                >
                <option value="fund_deposit_status_change"
                  >Fund Deposit Status Change</option
                >
              </optgroup>
              <optgroup label="User Management">
                <option value="user_profile_update">User Profile Update</option>
                <option value="user_role_change"
                  >User Role Change (Promotion)</option
                >
              </optgroup>
            </select>
          </div>

          <button id="send-test-email" class="btn-primary">
            Send Test Email
          </button>

          <div id="status-message" class="status-message"></div>
        </div>

        <div class="info-box">
          <h3>ℹ️ Important Notes</h3>
          <ul>
            <li>All emails use the same production routes and functions</li>
            <li>Test data is realistic but clearly marked as "TEST"</li>
            <li>Emails are sent via Resend API (production service)</li>
            <li>Check your spam folder if you don't receive the email</li>
          </ul>
        </div>
      </div>
    </DashboardLayout>

    <style>
      .email-testing-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
      }

      h1 {
        color: #00629b;
        margin-bottom: 0.5rem;
      }

      .subtitle {
        color: #666;
        margin-bottom: 2rem;
      }

      .test-form {
        background: white;
        border-radius: 8px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        margin-bottom: 2rem;
      }

      .form-group {
        margin-bottom: 1.5rem;
      }

      label {
        display: block;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #333;
      }

      input[type="email"],
      select {
        width: 100%;
        padding: 0.75rem;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 1rem;
      }

      input[type="email"]:focus,
      select:focus {
        outline: none;
        border-color: #00629b;
        box-shadow: 0 0 0 3px rgba(0, 98, 155, 0.1);
      }

      .btn-primary {
        background: #00629b;
        color: white;
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 4px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        width: 100%;
        transition: background 0.2s;
      }

      .btn-primary:hover {
        background: #004b7a;
      }

      .btn-primary:disabled {
        background: #ccc;
        cursor: not-allowed;
      }

      .status-message {
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 4px;
        display: none;
      }

      .status-message.success {
        display: block;
        background: #d4edda;
        color: #155724;
        border: 1px solid #c3e6cb;
      }

      .status-message.error {
        display: block;
        background: #f8d7da;
        color: #721c24;
        border: 1px solid #f5c6cb;
      }

      .status-message.loading {
        display: block;
        background: #d1ecf1;
        color: #0c5460;
        border: 1px solid #bee5eb;
      }

      .info-box {
        background: #e7f3ff;
        border-left: 4px solid #00629b;
        padding: 1.5rem;
        border-radius: 4px;
      }

      .info-box h3 {
        margin-top: 0;
        color: #00629b;
      }

      .info-box ul {
        margin: 0;
        padding-left: 1.5rem;
      }

      .info-box li {
        margin-bottom: 0.5rem;
      }
    </style>

    <script>
      const testEmailInput = document.getElementById(
        "test-email",
      ) as HTMLInputElement | null;
      const emailTypeSelect = document.getElementById(
        "email-type",
      ) as HTMLSelectElement | null;
      const sendButton = document.getElementById(
        "send-test-email",
      ) as HTMLButtonElement | null;
      const statusMessage = document.getElementById(
        "status-message",
      ) as HTMLDivElement | null;

      sendButton?.addEventListener("click", async () => {
        const testEmail = (testEmailInput as HTMLInputElement)?.value?.trim();
        const emailType = (emailTypeSelect as HTMLSelectElement)?.value;

        if (!testEmail || !emailType) {
          showStatus("Please fill in all fields", "error");
          return;
        }

        if (!isValidEmail(testEmail)) {
          showStatus("Please enter a valid email address", "error");
          return;
        }

        if (sendButton) sendButton.disabled = true;
        showStatus("Sending test email...", "loading");

        try {
          const response = await fetch("/api/email/send-test-email", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              testEmail,
              emailType,
            }),
          });

          const result = await response.json();

          if (response.ok && result.success) {
            showStatus(
              `✅ Test email sent successfully to ${testEmail}!`,
              "success",
            );
          } else {
            showStatus(
              `❌ Failed to send email: ${result.error || "Unknown error"}`,
              "error",
            );
          }
        } catch (error) {
          showStatus(
            `❌ Error: ${error instanceof Error ? error.message : "Unknown error"}`,
            "error",
          );
        } finally {
          if (sendButton) sendButton.disabled = false;
        }
      });

      function showStatus(message: string, type: string) {
        if (statusMessage) {
          statusMessage.textContent = message;
          statusMessage.className = `status-message ${type}`;
        }
      }

      function isValidEmail(email: string): boolean {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      }
    </script>
  </body>
</html>
