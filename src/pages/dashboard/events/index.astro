---
import DashboardLayout from "../../../components/dashboard/shared/DashboardLayout.tsx";
import DashboardHead from "../../../components/dashboard/shared/DashboardHead.astro";
import EventsContent from "../../../components/dashboard/pages/events/EventsContent.tsx";
import { NAVIGATION_PATHS } from "../../../components/dashboard/shared/types/navigation";

const title = "Events - Dashboard";
const currentPath = NAVIGATION_PATHS.EVENTS;
---

<!doctype html>
<html lang="en">
  <head>
    <DashboardHead title={title} />
  </head>
  <body>
    <DashboardLayout currentPath={currentPath} client:load>
      <EventsContent client:load />
    </DashboardLayout>
  </body>
</html>
