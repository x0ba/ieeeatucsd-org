rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers (available to all matches below) =====
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath(uid) {
      return '/databases/' + database + '/documents/users/' + uid;
    }

    function userExists(uid) {
      return exists(userDocPath(uid));
    }

    function userRole(uid) {
      // Only call when userExists(uid) is true
      return get(userDocPath(uid)).data.role;
    }

    function hasAnyRole(roles) {
      return isSignedIn() && userExists(request.auth.uid) &&
             userRole(request.auth.uid) in roles;
    }

    function isOfficer() {
      return hasAnyRole(['General Officer','Executive Officer','Administrator']);
    }

    function isExecOrAdmin() {
      return hasAnyRole(['Executive Officer','Administrator']);
    }

    // Validate that only allowed keys changed in an update.
    // Uses Map.diff() to avoid brittle key logic.
    function onlyChangedKeys(allowedKeys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowedKeys);
    }

    // Validate that none of the forbidden keys were added/changed.
    function noForbiddenKeys(forbidden) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(forbidden);
    }

    // ===== Users =====
    match /users/{userId} {
      // Self can read
      allow get: if isSignedIn() && request.auth.uid == userId;

      // Officers, Sponsors, and Admins can read any user
      allow get: if hasAnyRole(['General Officer','Executive Officer','Administrator','Sponsor']);

      // Listing users: officers & sponsors only (no resource access in list rules)
      allow list: if hasAnyRole(['General Officer','Executive Officer','Administrator','Sponsor']);

      // Create own user doc with a safe shape (no role escalation on create)
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && !('role' in request.resource.data); // role set server-side only

      // Base: Exec/Admin can update/delete any user (with extra guard for delete below)
      allow update: if isExecOrAdmin();
      allow delete: if hasAnyRole(['Administrator']); // only Admin can delete accounts

      // Self-service updates: user can update a limited profile subset
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && onlyChangedKeys([
            'lastEventAttended','points','eventsAttended',
            'name','major','graduationYear'
          ])
        && noForbiddenKeys(['role','ieeeEmail']); // block privilege/immutable fields

      // Allow setting IEEE email metadata once: cannot set 'ieeeEmail' if already present
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAny(['hasIEEEEmail','ieeeEmailCreatedAt'])
        && ( !exists(/databases/$(database)/documents/users/$(userId))
             || !get(/databases/$(database)/documents/users/$(userId)).data.keys().hasAny(['ieeeEmail']) );

      // Officers + Past Officer can update 'ieeeEmailStatus' only
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && onlyChangedKeys(['ieeeEmailStatus'])
        && hasAnyRole(['General Officer','Executive Officer','Past Officer','Administrator']);

      // Admins can manage IEEE email fields explicitly
      allow update: if hasAnyRole(['Administrator'])
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['hasIEEEEmail','ieeeEmail','ieeeEmailCreatedAt','ieeeEmailStatus']);

      // Public profile subcollection (authenticated read; self write; officers manage)
      match /public_profile/{profileId} {
        allow read: if isSignedIn();
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && profileId == 'profile';
        allow create, update, delete: if isOfficer();
      }
    }

    // ===== Invites =====
    match /invites/{inviteId} {
      // Officers manage invites
      allow create, update, delete: if isOfficer();

      // Invitee can read & update their invite (status transition only)
      allow get: if isSignedIn() && request.auth.token.email == resource.data.email;
      allow update: if isSignedIn()
        && request.auth.token.email == resource.data.email
        && request.resource.data.status in ['accepted','declined']
        && onlyChangedKeys(['status']); // status only
    }

    // ===== Events =====
    match /events/{eventId} {
      // Public events: readable when published
      // (works for queries: each returned doc must satisfy this predicate)
      allow read: if resource.data.published == true || isOfficer();

      // Create: officers OR owners of approved event_requests
      allow create: if isOfficer()
        || ( isSignedIn()
             && request.resource.data.createdFrom != null
             && exists(/databases/$(database)/documents/event_requests/$(request.resource.data.createdFrom))
             && get(/databases/$(database)/documents/event_requests/$(request.resource.data.createdFrom)).data.requestedUser == request.auth.uid );

      // Update by owner via event_request link
      allow update: if isSignedIn()
        && resource.data.createdFrom != null
        && exists(/databases/$(database)/documents/event_requests/$(resource.data.createdFrom))
        && get(/databases/$(database)/documents/event_requests/$(resource.data.createdFrom)).data.requestedUser == request.auth.uid;

      // Legacy GO path & Exec/Admin manage
      allow update, delete: if hasAnyRole(['Executive Officer','Administrator'])
        || ( hasAnyRole(['General Officer'])
             && resource.data.requestedUser == request.auth.uid
             && resource.data.status in ['submitted','pending'] );

      // Attendees may add themselves to a *published* event; field-scoped update only
      allow update: if resource.data.published == true
        && onlyChangedKeys(['attendees'])
        && isSignedIn()
        && !(request.auth.uid in resource.data.get('attendees', []))
        && (request.auth.uid in request.resource.data.attendees)
        && (request.resource.data.attendees.size() == resource.data.get('attendees', []).size() + 1);

      match /attendees/{attendeeId} {
        // Attendee can create/read own attendance record
        allow create: if request.auth != null
          && request.auth.uid == attendeeId
          && request.resource.data.userId == request.auth.uid;

        allow get: if request.auth != null && request.auth.uid == attendeeId;

        // Officers can manage any attendee record
        allow read, write: if isOfficer();
      }
    }

    // ===== Event Requests =====
    match /event_requests/{requestId} {
      // Anyone authenticated can create their own request
      allow create: if isSignedIn()
        && request.resource.data.requestedUser == request.auth.uid;

      // Officers can create drafts with minimal required fields
      allow create: if isOfficer()
        && request.resource.data.status == 'draft'
        && request.resource.data.isDraft == true
        && request.resource.data.keys()
             .hasAll(['name','startDateTime','requestedUser','status','isDraft']);

      // Officers can read/create/update any request
      allow read, create, update: if isOfficer();

      // Draft -> submitted/pending
      allow update: if isOfficer()
        && resource.data.status == 'draft'
        && resource.data.isDraft == true
        && request.resource.data.status in ['submitted','pending']
        && onlyChangedKeys(['status']); // keep this transition tight

      // Audit log append/update by member+ (only auditLogs/updatedAt)
      allow update: if hasAnyRole(['Member','General Officer','Executive Officer','Administrator'])
        && onlyChangedKeys(['auditLogs','updatedAt']);

      // Owner controls their request (fallback; works for queries too)
      allow read, update, delete: if isSignedIn()
        && request.auth.uid == resource.data.requestedUser;

      // Graphics field updates by officers only
      allow update: if isOfficer()
        && onlyChangedKeys(['graphicsCompleted','graphicsFiles','updatedAt']);

      // Exec/Admin may change status / requestedUser / auditLogs
      allow update: if isExecOrAdmin()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['status','requestedUser','auditLogs','updatedAt']);

      // Exec/Admin full control (last fallback)
      allow read, update, delete: if isExecOrAdmin();
    }

    // ===== Reimbursements =====
    match /reimbursements/{reimbursementId} {
      // Owner read/delete own
      allow read, delete: if isSignedIn()
        && request.auth.uid == resource.data.submittedBy;

      // Owner can update while 'submitted' & cannot touch paymentConfirmation
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.submittedBy
        && resource.data.status == 'submitted'
        && noForbiddenKeys(['paymentConfirmation']);

      // Exec/Admin manage all
      allow read, update, delete: if isExecOrAdmin();

      // Create (owner only) with required fields; cannot set paymentConfirmation
      allow create: if isSignedIn()
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.status == 'submitted'
        && request.resource.data.keys()
             .hasAll(['title','totalAmount','status','submittedBy','department','businessPurpose','submittedAt'])
        && ( request.resource.data.keys().hasAny(['expenses']) || request.resource.data.keys().hasAny(['receipts']) )
        && !request.resource.data.keys().hasAny(['paymentConfirmation']);

      // Mark paid: Exec/Admin, add paymentConfirmation with structure, set status=paid
      allow update: if isExecOrAdmin()
        && request.resource.data.status == 'paid'
        && request.resource.data.keys().hasAny(['paymentConfirmation'])
        && request.resource.data.paymentConfirmation.keys().hasAll(['paidBy','paidAt'])
        && request.resource.data.paymentConfirmation.paidBy == request.auth.uid
        && (request.resource.data.paymentConfirmation.paidAt is timestamp);
    }

    // ===== Logs (officers only) =====
    match /logs/{logId} {
      allow read, write, delete: if isOfficer();
    }

    // ===== Templates (officers only) =====
    match /templates/{templateId} {
      allow read, write, delete: if isOfficer();
    }

    // ===== Public profiles (top-level mirror) =====
    match /public_profiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow create, update, delete: if isOfficer();
    }

    // ===== Officer leaderboard (officers read; exec/admin write) =====
    match /leaderboard/{document=**} {
      allow read: if isOfficer();
      allow write: if isExecOrAdmin();
    }

    // ===== Leaderboard settings (exec/admin create; officers read) =====
    match /leaderboard_settings/{settingsId} {
      allow read: if isOfficer();
      allow update: if isOfficer();
      allow create: if isExecOrAdmin() && settingsId == 'settings';
    }

    // ===== Fund Deposits =====
    match /fundDeposits/{depositId} {
      // Creators can create and read their own
      allow create: if isSignedIn()
        && request.resource.data.depositedBy == request.auth.uid;

      allow get: if isSignedIn()
        && resource.data.depositedBy == request.auth.uid;

      // Officers read all; Admins update/delete
      allow read: if hasAnyRole(['General Officer','Executive Officer','Administrator']);
      allow update, delete: if hasAnyRole(['Administrator']);

      // Creators can delete while pending
      allow delete: if isSignedIn()
        && resource.data.depositedBy == request.auth.uid
        && resource.data.status == 'pending';
    }

    // ===== Constitution Builder (exec/admin manage) =====
    match /constitutions/{constitutionId} {
      allow read: if isSignedIn();
      allow create, update: if isExecOrAdmin();
      allow delete: if hasAnyRole(['Administrator']);

      match /sections/{sectionId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isExecOrAdmin();
      }

      match /auditLog/{auditEntryId} {
        allow read: if isSignedIn();
        // Officers create their own audit entries; immutable afterwards
        allow create: if isExecOrAdmin()
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ===== Notifications (per-user) =====
    match /notifications/{notificationId} {
      // Read/update only your own notification; works for queries too
      allow read, update: if isSignedIn() && resource.data.userId == request.auth.uid;

      // Officers can create notifications for any user
      allow create: if isOfficer();

      // Officers can delete any notification
      allow delete: if isOfficer();
    }

    // ===== Links (members read; officers manage) =====
    match /links/{linkId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOfficer();
    }

    // ===== Sponsor Domains (admin only) =====
    match /sponsorDomains/{domainId} {
      allow get, list, create, update, delete: if hasAnyRole(['Administrator']);
    }

    // ===== Officer Invitations =====
    match /officerInvitations/{inviteId} {
      // Exec/Admin manage
      allow create, read, update, list: if isExecOrAdmin();

      // Public can GET a specific invite (e.g., accept page) but cannot LIST
      allow get: if true;
      allow list: if false;

      // Public may flip status only; immutable other fields
      allow update: if onlyChangedKeys(['status','acceptedAt','declinedAt','onboardingEmailSent','googleGroupAssigned','googleGroup','permissionsGranted']);

      // Admin can delete
      allow delete: if hasAnyRole(['Administrator']);
    }

    // ===== Direct Onboardings =====
    match /directOnboardings/{onboardingId} {
      allow create, read, list: if isExecOrAdmin();
      allow update, delete: if hasAnyRole(['Administrator']);
    }

    // ===== Google Group Assignments =====
    match /googleGroupAssignments/{assignmentId} {
      allow read, list: if isExecOrAdmin();

      // IMPORTANT: Do NOT allow unauthenticated create here from clients.
      // Use Admin SDK instead (rules are bypassed by server credentials).
      allow create: if false;

      allow update, delete: if hasAnyRole(['Administrator']);
    }

    // ===== Organization Settings =====
    match /organizationSettings/{settingId} {
      allow read, get: if isExecOrAdmin();
      allow create, update: if isExecOrAdmin();
      allow delete: if hasAnyRole(['Administrator']);
    }

    // Default deny
    match /{document=**} {
      allow read, write, delete: if false;
    }
  }
}
