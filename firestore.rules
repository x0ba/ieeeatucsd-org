rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers (available to all matches below) =====
    function isSignedIn() {
      return request.auth != null;
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function userRole(uid) {
      // Only call when userExists(uid) is true
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function hasAnyRole(roles) {
      return isSignedIn()
        && userExists(request.auth.uid)
        && userRole(request.auth.uid) in roles;
    }

    function isOfficer() {
      return hasAnyRole(['General Officer', 'Executive Officer', 'Administrator']);
    }

    function isExecOrAdmin() {
      return hasAnyRole(['Executive Officer', 'Administrator']);
    }

    // Validate that only allowed keys changed in an update.
    function onlyChangedKeys(allowedKeys) {
      return request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasOnly(allowedKeys);
    }

    // Validate that none of the forbidden keys were added/changed.
    function noForbiddenKeys(forbidden) {
      return !request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasAny(forbidden);
    }

    // ===== Users =====
    match /users/{userId} {
      // Read: self OR officers/sponsors
      allow get: if isSignedIn()
        && (
          request.auth.uid == userId
          || hasAnyRole(['General Officer','Executive Officer','Administrator','Sponsor'])
        );

      // List: officers & sponsors only
      allow list: if hasAnyRole(['General Officer','Executive Officer','Administrator','Sponsor']);

      // Create own user doc (no role on create)
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && !('role' in request.resource.data);

      // Exec/Admin can update/delete any user
      allow update: if isExecOrAdmin();
      allow delete: if hasAnyRole(['Administrator']);

      // Self-service profile update (limited fields)
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && onlyChangedKeys([
          'lastEventAttended',
          'points',
          'eventsAttended',
          'name',
          'major',
          'graduationYear',
          'pid',
          'memberId',
          'zelleInformation',
          'resume',
          'signedUp',
          'joinDate',
          'navigationLayout'
        ])
        && noForbiddenKeys(['role','ieeeEmail']);

      // Allow setting IEEE email metadata once (no ieeeEmail yet)
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAny([
          'hasIEEEEmail',
          'ieeeEmailCreatedAt'
        ])
        && (
          !exists(/databases/$(database)/documents/users/$(userId))
          || !get(/databases/$(database)/documents/users/$(userId))
              .data.keys()
              .hasAny(['ieeeEmail'])
        );

      // Officers + Past Officer can update ieeeEmailStatus only
      allow update: if isSignedIn()
        && onlyChangedKeys(['ieeeEmailStatus'])
        && hasAnyRole([
          'General Officer',
          'Executive Officer',
          'Past Officer',
          'Administrator'
        ]);

      // Admins can manage IEEE email fields explicitly
      allow update: if hasAnyRole(['Administrator'])
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly([
            'hasIEEEEmail',
            'ieeeEmail',
            'ieeeEmailCreatedAt',
            'ieeeEmailStatus'
          ]);

      // Public profile subcollection (per-user)
      match /public_profile/{profileId} {
        allow read: if isSignedIn();

        // User manages their own profile doc
        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && profileId == 'profile';

        // Officers manage any profile
        allow create, update, delete: if isOfficer();
      }
    }

    // ===== Invites =====
    match /invites/{inviteId} {
      // Officers manage invites
      allow create, update, delete: if isOfficer();

      // Invitee can read their invite
      allow get: if isSignedIn()
        && request.auth.token.email == resource.data.email;

      // Invitee can only change status
      allow update: if isSignedIn()
        && request.auth.token.email == resource.data.email
        && request.resource.data.status in ['accepted','declined']
        && onlyChangedKeys(['status']);
    }

    // ===== Events =====
    match /events/{eventId} {
      // Public events readable when published; officers see all
      allow read: if resource.data.published == true || isOfficer();

      // Create: officers OR owner via approved event_request
      allow create: if isOfficer()
        || (
          isSignedIn()
          && request.resource.data.createdFrom != null
          && exists(/databases/$(database)/documents/event_requests/$(request.resource.data.createdFrom))
          && get(/databases/$(database)/documents/event_requests/$(request.resource.data.createdFrom))
              .data.requestedUser == request.auth.uid
        );

      // Update by owner via event_request link
      allow update: if isSignedIn()
        && resource.data.createdFrom != null
        && exists(/databases/$(database)/documents/event_requests/$(resource.data.createdFrom))
        && get(/databases/$(database)/documents/event_requests/$(resource.data.createdFrom))
            .data.requestedUser == request.auth.uid;

      // Exec/Admin manage all events
      allow update, delete: if hasAnyRole(['Executive Officer','Administrator']);

      // General Officer can manage their own events while early status
      allow update, delete: if hasAnyRole(['General Officer'])
        && resource.data.createdFrom != null
        && exists(/databases/$(database)/documents/event_requests/$(resource.data.createdFrom))
        && get(/databases/$(database)/documents/event_requests/$(resource.data.createdFrom))
            .data.requestedUser == request.auth.uid
        && resource.data.status in ['submitted','pending'];

      // Attendees may add themselves to a published event (attendees field only)
      allow update: if resource.data.published == true
        && onlyChangedKeys(['attendees'])
        && isSignedIn()
        && !(request.auth.uid in resource.data.get('attendees', []))
        && (request.auth.uid in request.resource.data.attendees)
        && (request.resource.data.attendees.size()
              == resource.data.get('attendees', []).size() + 1);

      // Event attendees subcollection
      match /attendees/{attendeeId} {
        // Attendee can create/read own record
        allow create: if isSignedIn()
          && request.auth.uid == attendeeId
          && request.resource.data.userId == request.auth.uid;

        allow get: if isSignedIn()
          && request.auth.uid == attendeeId;

        // Allow signed-in users to query attendee records
        // Security enforced by query where clause: where('userId', '==', user.uid)
        allow list: if isSignedIn();

        // Officers can manage any attendee record
        allow read, write: if isOfficer();

        // Any signed-in user can read attendee records for:
        // - published events
        // - events they created (via event_request)
        allow read: if isSignedIn()
          && exists(/databases/$(database)/documents/events/$(eventId))
          && (
            get(/databases/$(database)/documents/events/$(eventId))
              .data.published == true
            || (
              get(/databases/$(database)/documents/events/$(eventId))
                .data.createdFrom != null
              && exists(
                   /databases/$(database)/documents/event_requests/$(
                     get(/databases/$(database)/documents/events/$(eventId))
                       .data.createdFrom
                   )
                 )
              && get(
                   /databases/$(database)/documents/event_requests/$(
                     get(/databases/$(database)/documents/events/$(eventId))
                       .data.createdFrom
                   )
                 ).data.requestedUser == request.auth.uid
            )
            || isOfficer()
          );
      }
    }

    // ===== Event Requests =====
    match /event_requests/{requestId} {
      // Any authenticated user can create their own request
      allow create: if isSignedIn()
        && request.resource.data.requestedUser == request.auth.uid;

      // Officers can create drafts with minimal required fields
      allow create: if isOfficer()
        && request.resource.data.status == 'draft'
        && request.resource.data.isDraft == true
        && request.resource.data.keys()
             .hasAll(['name','startDateTime','requestedUser','status','isDraft']);

      // Officers can read any request
      allow read: if isOfficer();
  
      // Exec/Admin can create/update any request
      allow create, update: if hasAnyRole(['Executive Officer','Administrator']);
  
      // General Officers can update their own requests with full field access
      allow update: if hasAnyRole(['General Officer'])
        && resource.data.requestedUser == request.auth.uid;

      // Audit log updates by Member+
      allow update: if hasAnyRole([
          'Member',
          'General Officer',
          'Executive Officer',
          'Administrator'
        ])
        && onlyChangedKeys(['auditLogs','updatedAt']);

      // Owner controls their request (fallback)
      allow read, update, delete: if isSignedIn()
        && request.auth.uid == resource.data.requestedUser;

      // Graphics fields (officers only)
      allow update: if isOfficer()
        && onlyChangedKeys(['graphicsCompleted','graphicsFiles','updatedAt']);

      // Exec/Admin can tweak status/requestedUser/auditLogs
      allow update: if isExecOrAdmin()
        && request.resource.data
             .diff(resource.data)
             .affectedKeys()
             .hasOnly(['status','requestedUser','auditLogs','updatedAt']);

      // Exec/Admin full control (last fallback)
      allow read, update, delete: if isExecOrAdmin();
    }

    // ===== Reimbursements =====
    match /reimbursements/{reimbursementId} {
      // Owner read/delete own
      allow read, delete: if isSignedIn()
        && request.auth.uid == resource.data.submittedBy;

      // Owner can update while 'submitted' & cannot touch paymentConfirmation
      allow update: if isSignedIn()
        && request.auth.uid == resource.data.submittedBy
        && resource.data.status == 'submitted'
        && noForbiddenKeys(['paymentConfirmation']);

      // Exec/Admin manage all
      allow read, update, delete: if isExecOrAdmin();

      // Create (owner only) with required fields; no paymentConfirmation
      allow create: if isSignedIn()
        && request.resource.data.submittedBy == request.auth.uid
        && request.resource.data.status == 'submitted'
        && request.resource.data.keys()
             .hasAll([
               'title',
               'totalAmount',
               'status',
               'submittedBy',
               'department',
               'businessPurpose',
               'submittedAt'
             ])
        && (
          request.resource.data.keys().hasAny(['expenses'])
          || request.resource.data.keys().hasAny(['receipts'])
        )
        && !request.resource.data.keys().hasAny(['paymentConfirmation']);

      // Mark paid: Exec/Admin only
      allow update: if isExecOrAdmin()
        && request.resource.data.status == 'paid'
        && request.resource.data.keys().hasAny(['paymentConfirmation'])
        && request.resource.data.paymentConfirmation.keys()
             .hasAll(['paidBy','paidAt'])
        && request.resource.data.paymentConfirmation.paidBy == request.auth.uid
        && (request.resource.data.paymentConfirmation.paidAt is timestamp);
    }

    // ===== Logs (officers only) =====
    match /logs/{logId} {
      allow read, write, delete: if isOfficer();
    }

    // ===== Templates (officers only) =====
    match /templates/{templateId} {
      allow read, write, delete: if isOfficer();
    }

    // ===== Public profiles (top-level mirror) =====
    match /public_profiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.auth.uid == userId;
      allow create, update, delete: if isOfficer();
    }

    // ===== Officer leaderboard (officers read; exec/admin write) =====
    match /leaderboard/{document=**} {
      allow read: if isOfficer();
      allow write: if isExecOrAdmin();
    }

    // ===== Leaderboard settings (exec/admin create; officers read/update) =====
    match /leaderboard_settings/{settingsId} {
      allow read: if isOfficer();
      allow update: if isOfficer();
      allow create: if isExecOrAdmin()
        && settingsId == 'settings';
    }

    // ===== Fund Deposits =====
    match /fundDeposits/{depositId} {
      // Creators create and read their own
      allow create: if isSignedIn()
        && request.resource.data.depositedBy == request.auth.uid;

      allow get: if isSignedIn()
        && resource.data.depositedBy == request.auth.uid;

      // Officers read all; Admins update/delete
      allow read: if hasAnyRole([
        'General Officer',
        'Executive Officer',
        'Administrator'
      ]);

      allow update, delete: if hasAnyRole(['Administrator']);

      // Creators can delete while pending
      allow delete: if isSignedIn()
        && resource.data.depositedBy == request.auth.uid
        && resource.data.status == 'pending';
    }

    // ===== Constitution Builder =====
    match /constitutions/{constitutionId} {
      allow read: if isSignedIn();
      allow create, update: if isExecOrAdmin();
      allow delete: if hasAnyRole(['Administrator']);

      match /sections/{sectionId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isExecOrAdmin();
      }

      match /auditLog/{auditEntryId} {
        allow read: if isSignedIn();

        // Exec/Admin create immutable audit entries for themselves
        allow create: if isExecOrAdmin()
          && request.resource.data.userId == request.auth.uid;

        allow update, delete: if false;
      }
    }

    // ===== Notifications (per-user) =====
    match /notifications/{notificationId} {
      // Read/update only your own notification
      allow read, update: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      // Officers can create/delete for any user
      allow create: if isOfficer();
      allow delete: if isOfficer();
    }

    // ===== Links (members read; officers manage) =====
    match /links/{linkId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOfficer();
    }

    // ===== Sponsor Domains (admin only) =====
    match /sponsorDomains/{domainId} {
      allow get, list, create, update, delete: if hasAnyRole(['Administrator']);
    }

    // ===== Officer Invitations =====
    match /officerInvitations/{inviteId} {
      // Exec/Admin manage
      allow create, read, update, list: if isExecOrAdmin();

      // Public can GET but not LIST (for accept page)
      allow get: if true;
      allow list: if false;

      // Public may flip status/metadata only
      allow update: if onlyChangedKeys([
        'status',
        'acceptedAt',
        'declinedAt',
        'onboardingEmailSent',
        'googleGroupAssigned',
        'googleGroup',
        'permissionsGranted'
      ]);

      // Admin can delete
      allow delete: if hasAnyRole(['Administrator']);
    }

    // ===== Direct Onboardings =====
    match /directOnboardings/{onboardingId} {
      allow create, read, list: if isExecOrAdmin();
      allow update, delete: if hasAnyRole(['Administrator']);
    }

    // ===== Google Group Assignments =====
    match /googleGroupAssignments/{assignmentId} {
      allow read, list: if isExecOrAdmin();

      // No client-side create; use Admin SDK
      allow create: if false;

      allow update, delete: if hasAnyRole(['Administrator']);
    }

    // ===== Organization Settings =====
    match /organizationSettings/{settingId} {
      allow read, get: if isExecOrAdmin();
      allow create, update: if isExecOrAdmin();
      allow delete: if hasAnyRole(['Administrator']);
    }

    // ===== CollectionGroup queries =====
    // Allow users to query their own attendee records across all events
    match /{path=**}/attendees/{attendeeId} {
      allow read: if isSignedIn()
        && request.auth.uid == attendeeId;
      
      // Officers can read all attendee records
      allow read: if isOfficer();
    }

    // ===== Default deny =====
    match /{document=**} {
      allow read, write, delete: if false;
    }
  }
}
