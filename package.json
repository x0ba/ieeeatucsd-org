{
  "name": "ieeeatucsd-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:website": "bun run --cwd apps/website dev",
    "build:website": "bun run --cwd apps/website build",
    "dev:dashboard": "bun run --cwd apps/dashboard dev",
    "build:dashboard": "bun run --cwd apps/dashboard build"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1"
  }
}